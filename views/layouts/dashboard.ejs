<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="/resources/branding/favicon.png">
    <%- include('./styles'); %>
</head>
    <body class="sidebar-mini overflow-hidden">
        <div id="cortina" class="bg-primary text-white d-flex justify-content-center align-items-center">
            <span>
                Cargando...
            </span>
        </div>
        <!-- Site wrapper -->
        <div class="wrapper">
            <!-- Navbar -->
            <nav class="main-header navbar navbar-expand navbar-white navbar-light">
                <!-- Left navbar links -->
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                    </li>
                </ul>
            
                <!-- Right navbar links -->
                <ul class="navbar-nav ml-auto">
                    <li class="nav-item">
                        <button id="toggle-animations" class="nav-top-button btn btn-xs btn-flat btn-primary font-weight-bold" data-toggle="tooltip" data-trigger="hover" data-placement="bottom" title="Animaciones en ventanas emergentes"><i class="fas fa-play"></i></button>
                    </li>
                    <li class="nav-item">
                        <button id="toggle-thead-mode" class="nav-top-button btn btn-xs btn-flat btn-light font-weight-bold" data-toggle="tooltip" data-trigger="hover" data-placement="bottom" title="Enc. tabla fijos/moviles/auto"><i class="fas fa-table"></i></button>
                    </li>
                    <li class="nav-item">
                        <button id="toggle-upper-lower-case" class="nav-top-button btn btn-xs btn-flat btn-light font-weight-bold" data-toggle="tooltip" data-trigger="hover" data-placement="bottom" title="Tablas en mayúsculas">Aa</button>
                    </li>
                    <li class="nav-item">
                        <button id="toggle-sounds" class="nav-top-button btn btn-xs btn-flat btn-primary" data-toggle="tooltip" data-trigger="hover" data-placement="left" title="Sonidos"><i class="fas fa-volume-high"></i></button>
                    </li>
                    <li class="nav-item">
                        <button id="toggle-dark-mode" class="nav-top-button btn btn-xs btn-flat btn-outline-warning" data-toggle="tooltip" data-trigger="hover" data-placement="left" title="Modo oscuro/claro"><i class="fas fa-sun"></i></button>
                    </li>

                    <li class="nav-item d-none">
                        <a class="nav-link" data-widget="control-sidebar" data-slide="true" href="#" role="button">
                        <i class="fas fa-th-large"></i>
                        </a>
                    </li>
                </ul>
            </nav>
            <!-- /.navbar -->
            
            <!-- Main Sidebar Container -->
            <aside class="main-sidebar sidebar-dark-primary elevation-4">
                <!-- Brand Logo -->
                <a href="#" class="brand-link  logo-switch d-flex justify-content-center">
                    <img src="/resources/branding/imagen-menu-cerrado.png" alt="logo chico" class="brand-image-xl logo-xs" style="width: 45px; left:14px; top: 13px; filter: drop-shadow(3px 3px 2px #555)">
                    <img src="/resources/branding/imagen-menu-abierto.png" alt="logo grande" class="brand-image-xs logo-xl" style="left: 45px; filter: drop-shadow(3px 3px 2px #555)">
                </a>
            
                <!-- Sidebar -->
                <div class="sidebar">
                    <!-- Sidebar user (optional) -->
                    <div class="user-panel py-3">
                        <div class="p-2 border rounded-pill text-white text-truncate text-center">
                            <i class="fas fa-user mr-2"></i> <span id="emailUsuario">usuario@dominio.com</span>
                        </div>
                    </div>
                
                    <!-- Sidebar Menu -->
                    <nav class="mt-2">
                        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                            <li class="nav-item" nav="inicio">
                                <a href="/dashboard" class="nav-link">
                                    <i class="nav-icon fas fa-home"></i>
                                    <p>
                                        Inicio
                                        <!--<span class="right badge badge-danger">New</span>-->
                                    </p>
                                </a>
                            </li>
                            <li class="nav-item" nav="creditos-personales" permiso="menu.creditos-personales">
                                <a href="/dashboard/creditos-personales" class="nav-link">
                                    <i class="nav-icon fas fa-file-invoice-dollar"></i>
                                    <p>
                                        Créditos Personales
                                        <!--<span class="right badge badge-danger">New</span>-->
                                    </p>
                                </a>
                            </li>
                            <!-- <li class="nav-item" nav="cajas" permiso="menu.cajas">
                                <a href="/dashboard/cajas" class="nav-link">
                                    <i class="nav-icon fas fa-box"></i>
                                    <p>
                                        Cajas
                                    </p>
                                </a>
                            </li> -->
                            <li class="nav-item" nav="usuarios" permiso="menu.usuarios">
                                <a href="/dashboard/usuarios" class="nav-link">
                                    <i class="nav-icon fas fa-user-shield"></i>
                                    <p>
                                        Usuarios
                                        <!--<span class="right badge badge-danger">New</span>-->
                                    </p>
                                </a>
                            </li>
                            <li class="nav-item" nav="configuracion" permiso="menu.configuracion">
                                <a href="/dashboard/configuracion" class="nav-link">
                                    <i class="nav-icon fas fa-cogs"></i>
                                    <p>
                                        Configuración
                                        <!--<span class="right badge badge-danger">New</span>-->
                                    </p>
                                </a>
                            </li>
                            <li class="nav-item cp" nav="cerrar-sesion">
                                <a href="#" class="nav-link nav-logout">
                                    <i class="nav-icon fas fa-door-open text-light"></i>
                                    <p>
                                        Cerrar sesión
                                        <!--<span class="right badge badge-danger">New</span>-->
                                    </p>
                                </a>
                            </li>
                        </ul>
                    </nav>
                    <!-- /.sidebar-menu -->
                </div>
                <!-- /.sidebar -->
            </aside>
            
            <!-- Content Wrapper. Contains page content -->
            <div class="content-wrapper overflow-hidden">
                <div id="expiration" class="text-center py-1"><span name="text">Tu suscripción vence en 7 renuevala hacienco clic en </span><button class="btn btn-sm btn-primary btn-flat">renovar</button></div>
                <!-- Content Header (Page header) -->
                <section class="content-header">
                    <div class="container-fluid">
                        <div class="row mb-2">
                            <div class="col-auto">
                                <h1 id="pageName" style="display: inline-block;"><%= title %></h1>
                            </div>
                            <div class="col d-none">
                                <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="#">Home</a></li>
                                <li class="breadcrumb-item active">Blank Page</li>
                                </ol>
                            </div>
                        </div>
                    </div><!-- /.container-fluid -->
                </section>
            
                <!-- Main content -->
                <section class="content d-none" style="opacity: 0;">
                    <div class="container-fluid pb-5">
                        <%- include(page); %>
                    </div>
                </section>
                <!-- /.content -->
            </div>
            <!-- /.content-wrapper -->
            
            <footer class="main-footer d-none">
                <div class="float-right d-none d-sm-block">
                    <b>Version</b> 3.2.0
                </div>
                <strong>Copyright © 2014-2021 <a href="https://adminlte.io">AdminLTE.io</a>.</strong> All rights reserved.
            </footer>
            
          
        </div>
        <!-- ./wrapper -->

        <!-- audio -->
        <audio id="audioPlayer" class="d-none" controls>
            <source src="/resources/audios/success.mp3" type="audio/mp3" data-audio="success">
            <source src="/resources/audios/primary.mp3" type="audio/mp3" data-audio="primary">
            <source src="/resources/audios/warning.mp3" type="audio/mp3" data-audio="warning">
            <source src="/resources/audios/danger.mp3" type="audio/mp3" data-audio="danger">
            <source src="/resources/audios/info.mp3" type="audio/mp3" data-audio="info">

            <source src="/resources/audios/tap.mp3" type="audio/mp3" data-audio="tap">
            <source src="/resources/audios/noti1.mp3" type="audio/mp3" data-audio="noti1">
            <source src="/resources/audios/noti2.mp3" type="audio/mp3" data-audio="noti2">
            <source src="/resources/audios/scanner.mp3" type="audio/mp3" data-audio="scanner">
            <source src="/resources/audios/ray.mp3" type="audio/mp3" data-audio="ray">
            <source src="/resources/audios/error.mp3" type="audio/mp3" data-audio="error">
        </audio>
        <!-- ./audio -->

        <%- include('./scripts'); %>
        
    </body>
</html>
